{
  "description": "autorun v0.10 - unified daemon-based hook handler",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "/afs|/afa|/afj|/afst|/autorun|/autostop|/estop|/ar:",
        "hooks": [{ "type": "command", "command": "uv run --quiet --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/hook_entry.py --cli claude", "timeout": 10 }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash|ExitPlanMode",
        "hooks": [{ "type": "command", "command": "uv run --quiet --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/hook_entry.py --cli claude", "timeout": 10 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode|Write|Edit|Bash",
        "hooks": [{ "type": "command", "command": "uv run --quiet --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/hook_entry.py --cli claude", "timeout": 10 }]
      },
      {
        "matcher": "TaskCreate|TaskUpdate|TaskGet|TaskList",
        "hooks": [{ "type": "command", "command": "uv run --quiet --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/hook_entry.py --cli claude", "timeout": 10 }]
      }
    ],
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "uv run --quiet --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/hook_entry.py --cli claude", "timeout": 10 }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "uv run --quiet --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/hook_entry.py --cli claude", "timeout": 10 }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [{ "type": "command", "command": "uv run --quiet --project ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/hook_entry.py --cli claude", "timeout": 10 }]
      }
    ]
  }
}
