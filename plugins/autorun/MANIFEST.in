# Core documentation
include CLAUDE.md
include build_support.py
include setup.py

# Plugin metadata and configuration
recursive-include .claude-plugin *
recursive-include .codex-plugin *

# Plugin resources (commands, agents, skills - markdown and python)
recursive-include commands *
recursive-include agents *
recursive-include skills *
recursive-include hooks *.json *.py

# Scripts for daemon management
recursive-include scripts *.py

# Workspace configuration
include pyproject.toml
recursive-include src/autorun/gemini_template *.json *.py

# Exclude build artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
global-exclude *.tmp
