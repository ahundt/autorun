{
  "description": "clautorun v0.7 - unified daemon-based hook handler (python module)",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "/afs|/afa|/afj|/afst|/autorun|/autostop|/estop|/cr:",
        "hooks": [{ "type": "command", "command": "python3 -m clautorun", "timeout": 10 }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Bash",
        "hooks": [{ "type": "command", "command": "python3 -m clautorun", "timeout": 10 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [{ "type": "command", "command": "python3 -m clautorun", "timeout": 10 }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "python3 -m clautorun", "timeout": 10 }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [{ "type": "command", "command": "python3 -m clautorun", "timeout": 10 }]
      }
    ]
  }
}
