{
  "description": "clautorun command interceptor and AutoFile policy enforcement hooks",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT}/src && PYTHONPATH=. python3 -m clautorun",
            "timeout": 10
          }
        ],
        "matcher": "/afs|/afa|/afj|/afst|/autorun|/autostop|/estop|/cr:"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT}/src && PYTHONPATH=. python3 -m clautorun",
            "timeout": 10
          }
        ],
        "matcher": "Write|Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/clautorun/main.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/src/clautorun/main.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
