{
  "description": "clautorun v0.8 - Gemini CLI native compatibility hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{
          "name": "clautorun-init",
          "type": "command",
          "command": "uv run --quiet --project ${extensionPath} python ${extensionPath}/hooks/hook_entry.py",
          "timeout": 10000
        }]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "/afs|/afa|/afj|/afst|/autorun|/autostop|/estop|/cr:",
        "hooks": [{
          "name": "clautorun-command",
          "type": "command",
          "command": "uv run --quiet --project ${extensionPath} python ${extensionPath}/hooks/hook_entry.py",
          "timeout": 10000
        }]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "write_file|run_shell_command|replace",
        "hooks": [{
          "name": "clautorun-pretool",
          "type": "command",
          "command": "uv run --quiet --project ${extensionPath} python ${extensionPath}/hooks/hook_entry.py",
          "timeout": 10000
        }]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [{
          "name": "clautorun-posttool-plan",
          "type": "command",
          "command": "uv run --quiet --project ${extensionPath} python ${extensionPath}/hooks/hook_entry.py",
          "timeout": 10000
        }]
      },
      {
        "matcher": "write_todos",
        "hooks": [{
          "name": "clautorun-posttool-task",
          "type": "command",
          "command": "uv run --quiet --project ${extensionPath} python ${extensionPath}/hooks/hook_entry.py",
          "timeout": 10000
        }]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{
          "name": "clautorun-cleanup",
          "type": "command",
          "command": "uv run --quiet --project ${extensionPath} python ${extensionPath}/hooks/hook_entry.py",
          "timeout": 10000
        }]
      }
    ]
  }
}
