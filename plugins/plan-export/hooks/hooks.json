{
  "description": "Hooks for plan export - includes workaround for fresh context bug",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/plan_export.py",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/check_unexported_plans.py",
        "timeout": 10
      }
    ]
  }
}
