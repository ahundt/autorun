{
  "description": "Hook to export plan files when exiting plan mode",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/plan_export.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
