%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '18px', 'fontFamily': 'Arial', 'maxTextWidth': 300, 'subgraphBkg': '#f7fafc', 'lineColor': '#4a5568', 'edgeLabelBackground': '#ffffff'}}}%%
flowchart TD
    %% ========================================
    %%  STYLING
    %% ========================================
    classDef stepBox fill:#1a365d,stroke:#2c5282,stroke-width:4px,color:#fff,font-size:20px,font-weight:bold;
    classDef choiceBox fill:#2b6cb0,stroke:#2c5282,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef aiBox fill:#276749,stroke:#22543d,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef guardBox fill:#c53030,stroke:#742a2a,stroke-width:3px,color:#fff,font-size:14px,font-weight:bold;
    classDef safeBox fill:#ed8936,stroke:#c05621,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef doneBox fill:#48bb78,stroke:#276749,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef settingBox fill:#718096,stroke:#4a5568,stroke-width:2px,color:#fff,font-size:15px,font-weight:bold;
    classDef settingsPanel fill:#e2e8f0,stroke:#a0aec0,stroke-width:2px,color:#2d3748,font-size:15px,font-weight:bold;

    %% ========================================
    %%  STEP 1: INSTALL
    %% ========================================
    INSTALL["💿 STEP 1<br/><br/>INSTALL AUTORUN"]:::stepBox
    INSTALL_CMD["uv pip install git+https://github.com/ahundt/autorun.git"]:::choiceBox

    %% ========================================
    %%  SETTINGS PANEL (Always available)
    %% ========================================
    subgraph SETTINGS["⚙️ SETTINGS"]
        direction TB

        subgraph FILE_SET["File Creation Policy"]
            F1["<b>File Controls:</b><br/>──────────<br/>Allow all file creation<br/>/ar:allow<br/>──────────<br/>Require justification before creating files<br/>/ar:justify<br/>──────────<br/>Find existing only, block all new files<br/>/ar:find<br/>──────────<br/>Show current policy<br/>/ar:status"]:::settingBox
        end

        FILE_SET --> BLOCK_SET

        subgraph BLOCK_SET["Command Redirecting"]
            direction LR
            B1["<b>Redirect dangerous commands to safer alternatives</b><br/>──────────<br/>Block in this session<br/>/ar:no &lt;pattern&gt; 'reason'<br/>──────────<br/>Allow in this session<br/>/ar:ok &lt;pattern&gt;<br/>──────────<br/>Clear session blocks<br/>/ar:clear [pattern]<br/>──────────<br/>Block in ALL sessions<br/>/ar:globalno &lt;pattern&gt; 'reason'<br/>──────────<br/>Allow in ALL sessions<br/>/ar:globalok &lt;pattern&gt;<br/>──────────<br/>Show global blocks<br/>/ar:globalstatus"]:::settingBox
        end
    end

    %% ========================================
    %%  STEP 2: CHOOSE HOW AI WORKS
    %% ========================================
    subgraph WORKFLOW_OPTIONS[" "]
        direction TB
        PROVIDE["📋 PROVIDE TASK INSTRUCTIONS"]:::stepBox
        subgraph WORKFLOW_CMDS[" "]
            direction LR
            W1["Run task directly<br/>──────────<br/>/ar:go &lt;instructions&gt;"]:::choiceBox

            W2["Multi-step projects<br/>──────────<br/>Create new plan<br/>/ar:plannew &lt;instructions&gt;<br/>──────────<br/>Refine plan<br/>/ar:planrefine &lt;instructions&gt;<br/>──────────<br/>Update plan<br/>/ar:planupdate &lt;instructions&gt;<br/>──────────<br/>Execute plan<br/>/ar:planprocess &lt;instructions&gt;"]:::choiceBox

            W1 --- W2
        end
        PROVIDE --> WORKFLOW_CMDS
    end

    WORKFLOW["🚀 START AUTONOMOUS WORK"]:::stepBox

    %% ========================================
    %%  STEP 3: AI WORKS
    %% ========================================
    AI_ENGINE["🤖 STEP 3<br/><br/>AI WORKS AUTONOMOUSLY<br/><br/>🔄 Loops until complete:<br/><br/>1️⃣ IMPLEMENT<br/>2️⃣ EVALUATE<br/>3️⃣ VERIFY<br/><br/>(You can step away!)"]:::aiBox

    %% ========================================
    %%  MONITOR & CONTROL (Optional)
    %% ========================================
    subgraph CONTROL_OPTIONS[" "]
        direction LR
        C1["<b>tmux/byobu</b><br/>──────────<br/>List all sessions<br/>/ar:tabs<br/>──────────<br/>Manage sessions<br/>/ar:tmux [list|create|cleanup]"]:::choiceBox
    end

    %% ========================================
    %%  COMPLETE
    %% ========================================
    COMPLETE["✅ TASK COMPLETE!"]:::doneBox

    %% ========================================
    %%  FLOW
    %% ========================================
    INSTALL --> INSTALL_CMD
    INSTALL_CMD --> WORKFLOW_OPTIONS

    WORKFLOW_OPTIONS --> WORKFLOW
    WORKFLOW --> AI_ENGINE
    WORKFLOW -.->|"adjust anytime"| SETTINGS

    WORKFLOW -.-> CONTROL_OPTIONS
    AI_ENGINE -->|"done"| COMPLETE

    %% Make all connector lines thicker
    linkStyle default stroke-width:6px
