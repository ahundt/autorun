#!/usr/bin/env python3
"""Claude Code plugin for Agent SDK command interception"""
import json
import sys
import os
from pathlib import Path

def main():
    """Plugin entry point for Claude Code"""
    try:
        # Read input from stdin
        input_data = sys.stdin.read()

        # Handle empty input
        if not input_data.strip():
            result = {
                "continue": True,
                "response": "",
                "error": "No input provided"
            }
            print(json.dumps(result, sort_keys=True))
            sys.stdout.flush()
            return

        # Parse JSON input
        try:
            payload = json.loads(input_data)
        except json.JSONDecodeError as e:
            result = {
                "continue": True,
                "response": "",
                "error": f"Invalid JSON: {e}"
            }
            print(json.dumps(result, sort_keys=True))
            sys.stdout.flush()
            return

        # Extract input data
        prompt = payload.get('prompt', '')
        session_id = payload.get('session_id', 'default')

        # Set up paths to find clautorun package
        plugin_file = Path(__file__).resolve()

        # Simple path detection - look for clautorun in common locations
        possible_project_roots = [
            plugin_file.parent.parent,  # ../ from commands/
            plugin_file.parent.parent / "clautorun",  # ../clautorun from commands/
            plugin_file.parent.parent.parent,  # ../../ from commands/
            Path.home() / ".claude" / "clautorun",  # Common location
        ]

        project_root = None
        for root in possible_project_roots:
            if (root / "src" / "clautorun").exists():
                project_root = root
                break

        if not project_root:
            # Fallback responses if we can't find clautorun
            simple_responses = {
                "/afs": "AutoFile policy: strict-search - STRICT SEARCH: ONLY modify existing files. Use Glob/Grep. NO new files.",
                "/afa": "AutoFile policy: allow-all - ALLOW ALL: Full permission to create/modify files.",
                "/afj": "AutoFile policy: justify-create - JUSTIFIED: Search existing first. Include <AUTOFILE_JUSTIFICATION>reason</AUTOFILE_JUSTIFICATION> for new files.",
                "/afst": "AutoFile policy status checking...",
            }

            response = None
            for cmd, resp in simple_responses.items():
                if prompt.startswith(cmd):
                    response = resp
                    break

            if response:
                result = {
                    "continue": False,
                    "response": response
                }
            else:
                result = {
                    "continue": True,
                    "response": ""
                }

            print(json.dumps(result, sort_keys=True))
            sys.stdout.flush()
            return

        # Change to project directory
        os.chdir(project_root)

        # Add src to Python path
        src_path = project_root / "src"
        if src_path.exists():
            sys.path.insert(0, str(src_path))

        # Try to import clautorun functionality
        try:
            from clautorun import CONFIG, COMMAND_HANDLERS, session_state
        except ImportError as e:
            # If import fails, use simple fallback responses
            simple_responses = {
                "/afs": "AutoFile policy: strict-search - STRICT SEARCH: ONLY modify existing files. Use Glob/Grep. NO new files.",
                "/afa": "AutoFile policy: allow-all - ALLOW ALL: Full permission to create/modify files.",
                "/afj": "AutoFile policy: justify-create - JUSTIFIED: Search existing first. Include <AUTOFILE_JUSTIFICATION>reason</AUTOFILE_JUSTIFICATION> for new files.",
                "/afst": "AutoFile policy status checking...",
            }

            response = None
            for cmd, resp in simple_responses.items():
                if prompt.startswith(cmd):
                    response = resp
                    break

            if response:
                result = {
                    "continue": False,
                    "response": response
                }
            else:
                result = {
                    "continue": True,
                    "response": ""
                }

            print(json.dumps(result, sort_keys=True))
            sys.stdout.flush()
            return

        # Use full clautorun functionality
        command = next((v for k, v in sorted(CONFIG["command_mappings"].items(), key=lambda x: len(x[0]), reverse=True) if prompt.startswith(k)), None)

        if command and command in COMMAND_HANDLERS:
            try:
                with session_state(session_id) as state:
                    if command == "activate":
                        response = COMMAND_HANDLERS[command](state, prompt)
                    else:
                        response = COMMAND_HANDLERS[command](state)

                from clautorun import build_response
                result = build_response(
                    continue_execution=False,
                    response=response
                )
            except Exception as e:
                from clautorun import build_response
                result = build_response(
                    continue_execution=True,
                    response="",
                    error=f"Command execution failed: {e}"
                )
        else:
            from clautorun import build_response
            result = build_response(
                continue_execution=True,
                response=""
            )

        print(json.dumps(result, sort_keys=True))
        sys.stdout.flush()

    except Exception as e:
        result = {
            "continue": True,
            "response": "",
            "error": f"Unexpected error: {e}"
        }
        print(json.dumps(result, sort_keys=True))
        sys.stdout.flush()

if __name__ == "__main__":
    main()