#!/usr/bin/env python3
"""Claude Code plugin for Agent SDK command interception - UV Tool wrapper"""
import json
import sys
import subprocess
import os
from pathlib import Path

def main():
    """Plugin entry point for Claude Code"""
    try:
        # Read input from stdin
        input_data = sys.stdin.read()

        # Handle empty input
        if not input_data.strip():
            result = {
                "continue": True,
                "response": "",
                "error": "No input provided"
            }
            print(json.dumps(result, sort_keys=True))
            sys.stdout.flush()
            return

        # Check if clautorun UV tool is available (preferred method)
        clautorun_cmd = None

        # Method 1: Check if clautorun UV tool is installed and available
        try:
            result = subprocess.run(
                ["which", "clautorun"],
                capture_output=True,
                text=True,
                timeout=5
            )
            if result.returncode == 0:
                clautorun_cmd = "clautorun"
        except (subprocess.TimeoutExpired, FileNotFoundError):
            pass

        # Method 2: Fallback to local package execution if UV tool not available
        if not clautorun_cmd:
            # Use local execution with path resolution
            plugin_file = Path(__file__).resolve()
            project_root = None

            # Check for UV_PROJECT environment variable first
            uv_project = os.environ.get('UV_PROJECT')
            if uv_project and (Path(uv_project) / "src" / "clautorun").exists():
                project_root = Path(uv_project)
            else:
                # Minimal fallback: check immediate parent
                potential_root = plugin_file.parent.parent
                if (potential_root / "src" / "clautorun").exists():
                    project_root = potential_root

            if project_root:
                # Use uv run to execute with proper environment
                clautorun_cmd = ["uv", "run", "--project", str(project_root), "python", "-m", "clautorun.claude_code_plugin"]
            else:
                # Final fallback - simple responses only
                simple_responses = {
                    "/afs": "AutoFile policy: strict-search - STRICT SEARCH: ONLY modify existing files. Use Glob/Grep. NO new files.",
                    "/afa": "AutoFile policy: allow-all - ALLOW ALL: Full permission to create/modify files.",
                    "/afj": "AutoFile policy: justify-create - JUSTIFIED: Search existing first. Include <AUTOFILE_JUSTIFICATION>reason</AUTOFILE_JUSTIFICATION> for new files.",
                    "/afst": "AutoFile policy status checking...",
                }

                payload = json.loads(input_data)
                prompt = payload.get('prompt', '')

                response = None
                for cmd, resp in simple_responses.items():
                    if prompt.startswith(cmd):
                        response = resp
                        break

                if response:
                    result = {
                        "continue": False,
                        "response": response
                    }
                else:
                    result = {
                        "continue": True,
                        "response": ""
                    }

                print(json.dumps(result, sort_keys=True))
                sys.stdout.flush()
                return

        # Execute clautorun command (either UV tool or local execution)
        try:
            if isinstance(clautorun_cmd, str):
                # UV tool installation
                result = subprocess.run(
                    [clautorun_cmd],
                    input=input_data,
                    text=True,
                    capture_output=True,
                    timeout=30
                )
            else:
                # Local execution with uv run
                result = subprocess.run(
                    clautorun_cmd,
                    input=input_data,
                    text=True,
                    capture_output=True,
                    timeout=30
                )

            # Parse and return the result - single JSON response only
            if result.stdout:
                try:
                    # Try to parse as JSON and forward
                    response_data = json.loads(result.stdout.strip())
                    # Add stderr as error field if present
                    if result.stderr:
                        response_data["error"] = result.stderr.strip()
                    print(json.dumps(response_data, sort_keys=True))
                except json.JSONDecodeError:
                    # If not JSON, wrap in proper response format
                    output = {
                        "continue": False,
                        "response": result.stdout.strip()
                    }
                    if result.stderr:
                        output["error"] = result.stderr.strip()
                    print(json.dumps(output, sort_keys=True))
            elif result.stderr:
                # Only stderr, no stdout - return error
                print(json.dumps({
                    "continue": True,
                    "response": "",
                    "error": result.stderr.strip()
                }, sort_keys=True))
            else:
                # No output at all - return empty continue
                print(json.dumps({
                    "continue": True,
                    "response": ""
                }, sort_keys=True))

        except subprocess.TimeoutExpired:
            print(json.dumps({
                "continue": True,
                "response": "",
                "error": "Command execution timed out"
            }, sort_keys=True))
        except Exception as e:
            print(json.dumps({
                "continue": True,
                "response": "",
                "error": f"Command execution failed: {e}"
            }, sort_keys=True))

        sys.stdout.flush()

    except Exception as e:
        result = {
            "continue": True,
            "response": "",
            "error": f"Unexpected error: {e}"
        }
        print(json.dumps(result, sort_keys=True))
        sys.stdout.flush()

if __name__ == "__main__":
    main()