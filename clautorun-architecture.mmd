%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '18px', 'fontFamily': 'Arial'}}}%%
flowchart TD
    %% ========================================
    %%  STYLING
    %% ========================================
    classDef stepBox fill:#1a365d,stroke:#2c5282,stroke-width:4px,color:#fff,font-size:20px,font-weight:bold;
    classDef choiceBox fill:#2b6cb0,stroke:#2c5282,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef aiBox fill:#276749,stroke:#22543d,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef guardBox fill:#c53030,stroke:#742a2a,stroke-width:3px,color:#fff,font-size:15px,font-weight:bold;
    classDef safeBox fill:#ed8936,stroke:#c05621,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef doneBox fill:#48bb78,stroke:#276749,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef infoBox fill:#718096,stroke:#4a5568,stroke-width:2px,color:#fff,font-size:13px,font-style:italic;

    %% ========================================
    %%  STEP 1: INSTALL
    %% ========================================
    INSTALL["💿 STEP 1<br/><br/>INSTALL CLAUTORUN<br/><br/>(one-time setup)"]:::stepBox
    INSTALL_CMD["/plugin install clautorun"]:::choiceBox
    INSTALL_INFO["📌 Adds plugin to Claude Code"]:::infoBox

    %% ========================================
    %%  STEP 2: CONTROL FILE CREATION
    %% ========================================
    POLICY["📁 STEP 2<br/><br/>CONTROL FILE CREATION<br/><br/>(default: AI can create any file)"]:::stepBox

    subgraph POLICY_OPTIONS[" "]
        direction LR
        P1["✅ /cr:a<br/>ALLOW ALL<br/><br/>🆕 New projects<br/>🆕 Prototyping<br/>🆕 Starting from scratch"]:::choiceBox
        P2["⚠️ /cr:j<br/>ASK FIRST<br/><br/>🔒 AI explains why<br/>🔒 Before creating files<br/>🔒 Balanced approach"]:::choiceBox
        P3["🔒 /cr:f<br/>EDIT ONLY<br/><br/>🚫 NO new files<br/>🚫 Refactoring existing code<br/>🚫 Bug fixes only"]:::choiceBox
        P4["📊 /cr:st<br/>SHOW STATUS"]:::choiceBox

        P1 --- P2 --- P3 --- P4
    end

    WHEN["💡 CHANGE ANYTIME<br/><br/>Start: /cr:a (create freely)<br/>Refactor: /cr:f (edit only)<br/>Add features: /cr:a (create again)"]:::infoBox

    %% ========================================
    %%  STEP 3: CHOOSE HOW AI WORKS
    %% ========================================
    WORKFLOW["🚀 STEP 3<br/><br/>START YOUR TASK"]:::stepBox

    subgraph WORKFLOW_OPTIONS[" "]
        direction LR
        W1["⚡ /cr:go<br/>AUTONOMOUS<br/><br/>🤖 AI works alone<br/>🤖 Fewer interruptions<br/>🤖 Best for: clear tasks<br/><br/>Example: /cr:go Add login form"]:::choiceBox

        W2["🔍 /cr:gp<br/>PROCEDURAL<br/><br/>📋 Structured process<br/>📋 Quality checks<br/>📋 Best for: complex tasks<br/><br/>Example: /cr:gp Build API"]:::choiceBox

        W3["📝 PLAN FIRST<br/><br/>/cr:pn - New plan<br/>/cr:pr - Refine plan<br/>/cr:pu - Update plan<br/>/cr:pp - Execute plan<br/><br/>Best for: Multi-step projects"]:::choiceBox

        W1 --- W2 --- W3
    end

    %% ========================================
    %%  STEP 4: AI WORKS (What happens next)
    %% ========================================
    AI_ENGINE["🤖 STEP 4<br/><br/>AI WORKS AUTONOMOUSLY<br/><br/>(You can step away!)"]:::aiBox

    LOOP["🔄 THREE-STAGE LOOP<br/><br/>1️⃣ IMPLEMENT - Build it<br/>2️⃣ EVALUATE - Check quality<br/>3️⃣ VERIFY - Confirm it works<br/><br/>🔄 Loops until task is complete<br/>✅ Then stops automatically"]:::aiBox

    EXAMPLE["📌 Example flow:<br/>AI creates login form → Checks it →<br/>Finds missing validation → Improves it →<br/>Checks again → Verifies tests pass → Done!"]:::infoBox

    %% ========================================
    %%  SAFETY LAYERS (Always protecting you)
    %% ========================================
    subgraph GUARDS["🛡️ BUILT-IN PROTECTIONS"]
        direction LR

        subgraph FILE_GUARD["📄 File Protection"]
            direction TB
            FG1["When AI tries to create files..."]:::guardBox
            FG2["🔒 Blocks if policy says 'edit only'<br/>✅ Allows if policy says 'allow all'<br/>⚠️ Asks for reason if policy says 'ask first'"]:::guardBox
            FG1 --> FG2
        end

        subgraph CMD_GUARD["⚠️ Command Blocking"]
            direction TB
            CG1["/cr:no rm - Block delete<br/>/cr:no git reset - Block destructive<br/>/cr:ok - Allow specific<br/>/cr:clear - Remove blocks"]:::guardBox
        end

        FILE_GUARD --- CMD_GUARD
    end

    %% ========================================
    %%  STEP 5: WATCH & CONTROL (Optional)
    %% ========================================
    CONTROL["🎮 STEP 5<br/><br/>WATCH & CONTROL<br/><br/>(while AI works - optional)"]:::stepBox

    subgraph CONTROL_OPTIONS[" "]
        direction LR
        C1["👀 /cr:tabs<br/>SEE SESSIONS<br/><br/>📊 See all AI sessions<br/>📊 What each is doing<br/>📊 Send commands<br/><br/>Example: Monitor 3 sessions<br/>building different parts"]:::choiceBox

        C2["🖥️ /cr:tm<br/>MANAGE TMUX<br/><br/>+ Create workspace<br/>+ List sessions<br/>+ Clean up old<br/><br/>Use: Isolated test env"]:::choiceBox

        C3["🛑 /cr:x<br/>STOP POLITELY<br/><br/>AI finishes current<br/>Then stops"]:::choiceBox

        C4["🚨 /cr:sos<br/>EMERGENCY STOP<br/><br/>⚠️ STOPS NOW<br/>⚠️ Doesn't wait"]:::safeBox

        C1 --- C2 --- C3 --- C4
    end

    %% ========================================
    %%  STEP 6: SURVIVE CRASHES
    %% ========================================
    RECOVERY["🕸️ STEP 6<br/><br/>CRASH RECOVERY<br/><br/>(if you disconnect)"]:::safeBox

    subgraph RECOVERY_OPTIONS[" "]
        direction LR
        R1["💾 SESSION SAVED<br/><br/>Work keeps running<br/>Even if you lose internet<br/>Even if computer crashes"]:::choiceBox

        R2["📱 RECONNECT<br/>FROM ANYWHERE<br/><br/>SSH from your phone<br/>Mosh for bad connections<br/>Pick up where you left off"]:::choiceBox

        R3["✅ WORK RESUMES<br/>AUTOMATICALLY<br/><br/>AI continues working<br/>Nothing was lost<br/>Seamless experience"]:::choiceBox

        R1 --- R2 --- R3
    end

    %% ========================================
    %%  SUCCESS!
    %% ========================================
    COMPLETE["✅ TASK COMPLETE!<br/><br/>🎉 AI did the work<br/>🎉 Files created/modified<br/>🎉 Review the results"]:::doneBox

    %% ========================================
    %%  FLOW CONNECTIONS (Top to Bottom)
    %% ========================================
    INSTALL --> INSTALL_CMD --> INSTALL_INFO
    INSTALL_INFO --> POLICY

    POLICY --> POLICY_OPTIONS
    POLICY_OPTIONS --> WHEN
    WHEN --> WORKFLOW

    WORKFLOW --> WORKFLOW_OPTIONS
    WORKFLOW_OPTIONS --> AI_ENGINE

    AI_ENGINE --> LOOP
    LOOP --> EXAMPLE

    LOOP -.->|"protected by"| GUARDS

    LOOP --> CONTROL
    CONTROL --> CONTROL_OPTIONS

    CONTROL_OPTIONS -.->|"optional"| RECOVERY
    RECOVERY --> RECOVERY_OPTIONS

    RECOVERY_OPTIONS -.->|"resume"| LOOP
    C4 -.->|"STOP NOW"| LOOP
    GUARDS -.->|"always on"| LOOP

    LOOP -->|"task done"| COMPLETE
