%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '18px', 'fontFamily': 'Arial', 'maxTextWidth': 300}}}%%
flowchart TD
    %% ========================================
    %%  STYLING
    %% ========================================
    classDef stepBox fill:#1a365d,stroke:#2c5282,stroke-width:4px,color:#fff,font-size:20px,font-weight:bold;
    classDef choiceBox fill:#2b6cb0,stroke:#2c5282,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef aiBox fill:#276749,stroke:#22543d,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef guardBox fill:#c53030,stroke:#742a2a,stroke-width:3px,color:#fff,font-size:14px,font-weight:bold;
    classDef safeBox fill:#ed8936,stroke:#c05621,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef doneBox fill:#48bb78,stroke:#276749,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef settingBox fill:#718096,stroke:#4a5568,stroke-width:2px,color:#fff,font-size:15px,font-weight:bold;

    %% ========================================
    %%  STEP 1: INSTALL
    %% ========================================
    INSTALL["💿 STEP 1<br/><br/>INSTALL CLAUTORUN"]:::stepBox
    INSTALL_CMD["/plugin install clautorun"]:::choiceBox

    %% ========================================
    %%  SETTINGS PANEL (Always available)
    %% ========================================
    subgraph SETTINGS["⚙️ SETTINGS - Adjust Anytime"]
        direction TB

        subgraph FILE_SET["Prevent or Allow AI<br/>from Creating Files"]
            direction LR
            F1["/cr:a<br/>Allow all file creation"]:::settingBox
            F2["/cr:j<br/>Require justification<br/>before creating files"]:::settingBox
            F3["/cr:f<br/>Find existing only<br/>(block all new files)"]:::settingBox
            F4["/cr:st<br/>Show current policy"]:::settingBox
            F1 --- F2 --- F3 --- F4
        end

        subgraph BLOCK_SET["Block AI's Destructive Commands"]
            direction LR
            B1["/cr:no <pattern> [desc]<br/>Block in this session"]:::settingBox
            B2["/cr:ok <pattern><br/>Allow in this session"]:::settingBox
            B3["/cr:clear [pattern]<br/>Clear session blocks"]:::settingBox
            B4["/cr:globalno <p> [desc]<br/>Block in ALL sessions"]:::settingBox
            B5["/cr:globalok <p><br/>Allow in ALL sessions"]:::settingBox
            B6["/cr:globalstatus<br/>Show global blocks"]:::settingBox
            B1 --- B2 --- B3 --- B4 --- B5 --- B6
        end
    end

    %% ========================================
    %%  STEP 2: START AUTONOMOUS WORK
    %% ========================================
    WORKFLOW["🚀 STEP 2<br/><br/>START AUTONOMOUS WORK"]:::stepBox

    subgraph WORKFLOW_OPTIONS[" "]
        direction LR
        W1["/cr:go <task><br/>AI works independently<br/>Best for clear tasks"]:::choiceBox

        W2["/cr:gp <task><br/>Structured with checks<br/>Best for complex tasks"]:::choiceBox

        W3["Plan commands:<br/><br/>/cr:pn - Create new plan<br/>/cr:pr - Refine plan<br/>/cr:pu - Update plan<br/>/cr:pp - Execute plan<br/><br/>Best for multi-step projects"]:::choiceBox

        W1 --- W2 --- W3
    end

    %% ========================================
    %%  STEP 3: AI WORKS
    %% ========================================
    AI_ENGINE["🤖 STEP 3<br/><br/>AI WORKS AUTONOMOUSLY"]:::aiBox

    LOOP["🔄 Loops until complete:<br/><br/>1️⃣ IMPLEMENT<br/>2️⃣ EVALUATE<br/>3️⃣ VERIFY<br/><br/>(You can step away!)"]:::aiBox

    %% ========================================
    %%  STEP 4: MONITOR & CONTROL
    %% ========================================
    CONTROL["🎮 STEP 4<br/><br/>MONITOR & CONTROL<br/><br/>(While AI Works)"]:::stepBox

    subgraph CONTROL_OPTIONS[" "]
        direction LR
        C1["/cr:tabs<br/>List all sessions<br/>with status info"]:::choiceBox

        C2["/cr:tm [list|create|cleanup]<br/>Manage tmux sessions"]:::choiceBox

        C3["/cr:x<br/>Stop after current task"]:::choiceBox

        C4["/cr:sos<br/>EMERGENCY STOP NOW"]:::safeBox

        C1 --- C2 --- C3 --- C4
    end

    %% ========================================
    %%  COMPLETE
    %% ========================================
    COMPLETE["✅ TASK COMPLETE!"]:::doneBox

    %% ========================================
    %%  FLOW
    %% ========================================
    INSTALL --> INSTALL_CMD
    INSTALL_CMD --> WORKFLOW

    SETTINGS -.->|"adjust anytime"| LOOP

    WORKFLOW --> WORKFLOW_OPTIONS
    WORKFLOW_OPTIONS --> AI_ENGINE

    AI_ENGINE --> LOOP
    LOOP --> CONTROL

    CONTROL --> CONTROL_OPTIONS

    C4 -.->|"STOP NOW"| LOOP
    LOOP -->|"done"| COMPLETE
