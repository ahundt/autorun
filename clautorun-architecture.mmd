%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '18px', 'fontFamily': 'Arial', 'maxTextWidth': 300, 'subgraphBkg': '#f7fafc', 'lineColor': '#a0aec0'}}}%%
flowchart TD
    %% ========================================
    %%  STYLING
    %% ========================================
    classDef stepBox fill:#1a365d,stroke:#2c5282,stroke-width:4px,color:#fff,font-size:20px,font-weight:bold;
    classDef choiceBox fill:#2b6cb0,stroke:#2c5282,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef aiBox fill:#276749,stroke:#22543d,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef guardBox fill:#c53030,stroke:#742a2a,stroke-width:3px,color:#fff,font-size:14px,font-weight:bold;
    classDef safeBox fill:#ed8936,stroke:#c05621,stroke-width:3px,color:#fff,font-size:16px,font-weight:bold;
    classDef doneBox fill:#48bb78,stroke:#276749,stroke-width:4px,color:#fff,font-size:18px,font-weight:bold;
    classDef settingBox fill:#718096,stroke:#4a5568,stroke-width:2px,color:#fff,font-size:15px,font-weight:bold;
    classDef settingsPanel fill:#e2e8f0,stroke:#a0aec0,stroke-width:2px,color:#2d3748,font-size:15px,font-weight:bold;

    %% ========================================
    %%  STEP 1: INSTALL
    %% ========================================
    INSTALL["💿 STEP 1<br/><br/>INSTALL CLAUTORUN"]:::stepBox
    INSTALL_CMD["/plugin install clautorun"]:::choiceBox

    %% ========================================
    %%  SETTINGS PANEL (Always available)
    %% ========================================
    subgraph SETTINGS["⚙️ SETTINGS"]
        direction TB

        subgraph FILE_SET["Prevent or Allow AI from Creating Files"]
            F1["<b>File Controls:</b><br/><br/>/cr:a - Allow all file creation<br/>/cr:j - Require justification before creating files<br/>/cr:f - Find existing only (block all new files)<br/>/cr:st - Show current policy"]:::settingBox
        end

        FILE_SET --> BLOCK_SET

        subgraph BLOCK_SET["Block AI's Destructive Commands"]
            direction LR
            B1["<b>Command Blocking:</b><br/><br/>/cr:no <pattern> 'why blocked'<br/>Block in this session<br/><br/>/cr:ok <pattern><br/>Allow in this session<br/><br/>/cr:clear [pattern]<br/>Clear session blocks<br/><br/>/cr:globalno <pattern> 'why blocked'<br/>Block in ALL sessions<br/><br/>/cr:globalok <pattern><br/>Allow in ALL sessions<br/><br/>/cr:globalstatus<br/>Show global blocks"]:::settingBox
        end
    end

    %% ========================================
    %%  STEP 2: START AUTONOMOUS WORK
    %% ========================================
    WORKFLOW["🚀 STEP 2<br/><br/>START AUTONOMOUS WORK"]:::stepBox

    subgraph WORKFLOW_OPTIONS[" "]
        direction LR
        W1["/cr:go <task><br/>AI works independently<br/>Best for clear tasks"]:::choiceBox

        W2["/cr:gp <task><br/>Structured with checks<br/>Best for complex tasks"]:::choiceBox

        W3["Plan commands:<br/><br/>/cr:pn - Create new plan<br/>/cr:pr - Refine plan<br/>/cr:pu - Update plan<br/>/cr:pp - Execute plan<br/><br/>Best for multi-step projects"]:::choiceBox

        W1 --- W2 --- W3
    end

    %% ========================================
    %%  STEP 3: AI WORKS
    %% ========================================
    AI_ENGINE["🤖 STEP 3<br/><br/>AI WORKS AUTONOMOUSLY<br/><br/>🔄 Loops until complete:<br/><br/>1️⃣ IMPLEMENT<br/>2️⃣ EVALUATE<br/>3️⃣ VERIFY<br/><br/>(You can step away!)"]:::aiBox

    %% ========================================
    %%  MONITOR & CONTROL (Optional)
    %% ========================================
    subgraph CONTROL_OPTIONS[" "]
        direction LR
        C1["<b>tmux/byobu:</b><br/><br/>/cr:tabs - List all sessions<br/>/cr:tm [list|create|cleanup] - Manage sessions"]:::choiceBox
    end

    %% ========================================
    %%  COMPLETE
    %% ========================================
    COMPLETE["✅ TASK COMPLETE!"]:::doneBox

    %% ========================================
    %%  FLOW
    %% ========================================
    INSTALL --> INSTALL_CMD
    INSTALL_CMD --> WORKFLOW

    SETTINGS -.->|"adjust anytime"| AI_ENGINE

    WORKFLOW --> WORKFLOW_OPTIONS
    WORKFLOW_OPTIONS --> AI_ENGINE

    AI_ENGINE --> CONTROL_OPTIONS
    AI_ENGINE -->|"done"| COMPLETE
